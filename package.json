{
  "name": "maipal-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MaiPal 脉伴 — Intelligent Traditional Chinese Medicine health-companion mobile app (Capacitor.js)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p worker/tsconfig.json && vite build",
    "preview": "vite preview --host",
    "deploy": "vite build && wrangler deploy",
    "deploy:pages": "vite build && wrangler pages deploy ./dist/client --project-name maipal-app --commit-dirty=true",
    "cf:types": "wrangler types",
    "db:apply:local": "wrangler d1 migrations apply maipal-db --local",
    "db:apply:remote": "wrangler d1 migrations apply maipal-db --remote",
    "db:seed:local": "wrangler d1 execute maipal-db --local --file=./seed.sql",
    "db:seed:remote": "wrangler d1 execute maipal-db --remote --file=./seed.sql",
    "cap:sync": "cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "cap run ios",
    "cap:run:android": "cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@capgo/capacitor-social-login": "^8.0.0",
    "hono": "^4.6.14",
    "lucide-react": "^0.487.0",
    "motion": "^12.23.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.6.3",
    "vite": "^6.3.5",
    "wrangler": "^3.99.0"
  }
}
